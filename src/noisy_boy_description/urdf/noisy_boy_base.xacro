<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="length" value="0.4"/>
    <xacro:property name="width" value="0.4"/>
    <xacro:property name="height" value="0.1"/>

    <xacro:property name="mass" value="2.0"/>
    <xacro:property name="wheel_mass" value="0.5"/>

    <xacro:property name="wheel_radius" value="0.1"/>
    <xacro:property name="wheel_width" value="0.05"/>

    <xacro:property name="caster_wheel_radius" value="0.05"/>

    
    <!-- BASE -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="${length} ${width} ${height}"/>
            </geometry>
            <origin xyz="0.0 0.0 ${height/2}" rpy="0 0 0"/>
            <material name="red"/>
        </visual>

        <xacro:box_inertia m="${mass}" x="${length}" y="${width}" z="${height}" o_xyz="0 0 ${height/2}" o_rpy="0 0 0"/>

        <collision>
            <geometry>
                <box size="${length} ${width} ${height}"/>
            </geometry>
            <origin xyz="0.0 0.0 ${height/2}" rpy="0 0 0"/>
        </collision>

    </link>
    <!-- LEFT WHEEL -->
    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>

            <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>

            <material name="grey"/>
        </visual>

        <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}" o_xyz="0 0 0" o_rpy="${pi/2} 0 0"/>

        <collision>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        </collision>
    </link>
    
    <!-- RIGHT WHEEL -->
    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>

            <material name="grey"/>
        </visual>

        <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}" o_xyz="0 0 0" o_rpy="${pi/2} 0 0"/>

        <collision>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        </collision>
    </link>
    
    <!-- FRONT CASTER -->
    <link name="front_caster_link">
        <visual>
            <geometry>
                <sphere radius="${caster_wheel_radius}"/>
            </geometry>
            <material name="grey"/>
        </visual>

        <xacro:sphere_inertia m="0.5" r="${caster_wheel_radius}" o_xyz="0 0 0" o_rpy="0 0 0"/>

        <collision>
            <geometry>
                <sphere radius="${caster_wheel_radius}"/>
            </geometry>
        </collision>
    </link>

    <!-- REAR CASTER -->
    <link name="rear_caster_link">
        <visual>
            <geometry>
                <sphere radius="${caster_wheel_radius}"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <xacro:sphere_inertia m="0.5" r="${caster_wheel_radius}" o_xyz="0 0 0" o_rpy="0 0 0"/>
        <collision>
            <geometry>
                <sphere radius="${caster_wheel_radius}"/>
            </geometry>
        </collision>
    </link>
    
    <link name="base_footprint"/>
    
    <!-- BASE -->
    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
    </joint>
    
    <!-- LEFT WHEEL JOINT -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0 ${(width/2)+(wheel_width/2)} 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>
    
    <!-- RIGHT WHEEL JOINT -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0 ${-((width/2)+(wheel_width/2))} 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <!-- FRONT CASTER -->
    <joint name="front_caster_joint" type="fixed">
        <parent link="base_link"/>
        <child link="front_caster_link"/>
        <origin xyz="${(length/2)-caster_wheel_radius} 0 -${wheel_radius-caster_wheel_radius}" rpy="0 0 0"/>
    </joint>

    <!-- REAR CASTER -->
    <joint name="rear_caster_joint" type="fixed">
        <parent link="base_link"/>
        <child link="rear_caster_link"/>
        <origin xyz="-${(length/2)-caster_wheel_radius} 0 -${wheel_radius-caster_wheel_radius}" rpy="0 0 0"/>
    </joint>

</robot>